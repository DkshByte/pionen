# ============================================================
# Pionen — Android .gitignore
# ============================================================

# ----- Secrets & Local Configuration -----
local.properties
*.keystore
*.jks
keystore.properties
signing.properties
secrets.properties

# ----- Build Outputs -----
build/
.gradle/
app/build/
app/release/          # signed APK outputs — never commit signed APKs to VCS

# ----- Logs & Debug Artifacts -----
*.log
build_log.txt
hs_err_pid*.log
replay_pid*.log
java_pid*.hprof

# ----- APK / AAB / Profiling -----
*.apk
*.aab
*.ap_
*.hprof

# ----- Android Studio IDE -----
*.iml
.idea/
*.orig
.DS_Store

# ----- Dev Artifacts -----
*.resolved
ui_blueprint.md.resolved
setup.ps1

# ----- Kotlin / Kapt -----
**/.kotlin/
**/generated/
**/kapt/

# ----- Gradle Wrapper -----
# Do NOT ignore gradlew, gradlew.bat, or gradle-wrapper files (needed for CI)

# ----- OS Files -----
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100
.Trashes
.fseventsd
.AppleDouble
.LSOverride

# ----- Test Results -----
test-results/
