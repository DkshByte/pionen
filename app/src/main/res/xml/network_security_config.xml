<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Pionen
    
    Security Policy:
    - Block all cleartext (HTTP) traffic
    - Enforce HTTPS for all network requests
    - Trust only system CAs by default
-->
<network-security-config>
    <!-- Block cleartext traffic globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Allow localhost for development if needed -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
