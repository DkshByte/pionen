# keystore.properties — EXAMPLE TEMPLATE
#
# Copy this file to keystore.properties (in the project root) and fill in
# your actual values. keystore.properties is .gitignore'd and must NEVER
# be committed to version control.
#
# For CI/CD, store these as GitHub Actions Secrets and expose them as
# environment variables instead of using this file. See .github/workflows/ci.yml.

# Path to the release keystore file (relative to project root)
storeFile=../pionen-release.jks

# Keystore password
storePassword=YOUR_STORE_PASSWORD

# Key alias inside the keystore
keyAlias=pionen

# Key password
keyPassword=YOUR_KEY_PASSWORD
